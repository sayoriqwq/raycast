{
  "name": "counter",
  "title": "Counter",
  "description": "Generic event counter with daily summary and audit logs",
  "icon": "icon.png",
  "author": "sayori",
  "license": "MIT",
  "commands": [
    {
      "name": "increment-counter",
      "title": "Record Counter Event",
      "description": "Record an event to the configured counter target",
      "mode": "no-view",
      "arguments": [
        {
          "name": "target",
          "placeholder": "Target key/name, e.g. qq",
          "type": "text",
          "required": false
        }
      ]
    }
  ],
  "preferences": [
    {
      "name": "defaultCounter",
      "type": "textfield",
      "required": false,
      "title": "Default Counter",
      "description": "Used when command argument is empty",
      "placeholder": "qq"
    },
    {
      "name": "counterAliases",
      "type": "textfield",
      "required": false,
      "title": "Counter Aliases",
      "description": "Format: alias=counter, alias2=counter2",
      "placeholder": "qq=qq,wechat=wechat"
    },
    {
      "name": "dataDirectory",
      "type": "textfield",
      "required": false,
      "title": "Data Directory",
      "description": "Storage path for daily and audit logs",
      "default": "/Users/sayori/.config/raycast/data/counter"
    },
    {
      "name": "timeZone",
      "type": "textfield",
      "required": false,
      "title": "Time Zone",
      "description": "IANA time zone, e.g. Asia/Shanghai",
      "default": "Asia/Shanghai"
    }
  ],
  "dependencies": {
    "@raycast/api": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "^19.2.14",
    "typescript": "latest"
  },
  "scripts": {
    "dev": "ray develop",
    "build": "ray build -e dev -o .ray-build && cp .ray-build/increment-counter.js .",
    "build:dist": "ray build -e dist -o dist",
    "lint": "ray lint"
  }
}
